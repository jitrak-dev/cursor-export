{
  "name": "cursor-sync",
  "displayName": "cursor-sync",
  "version": "0.0.4",
  "publisher": "jitrak-dev",
  "description": "Export Cursor chats to .cursor/chats (workspace)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jitrak-dev/cursor-sync.git",
    "directory": "packages/vscode-ext"
  },
  "bugs": {
    "url": "https://github.com/jitrak-dev/cursor-sync/issues"
  },
  "homepage": "https://github.com/jitrak-dev/cursor-sync#readme",
  "keywords": [
    "cursor",
    "chat",
    "export",
    "markdown",
    "composer",
    "cursor-sync"
  ],
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "cursorSync.exportNow",
        "title": "Cursor Sync: Export chats now",
        "category": "Cursor Sync"
      },
      {
        "command": "cursorSync.showOutput",
        "title": "Cursor Sync: Show output",
        "category": "Cursor Sync"
      }
    ],
    "configuration": {
      "title": "Cursor Sync",
      "properties": {
        "cursorSync.enabled": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "Watch Cursor/VS Code chat storage (`state.vscdb`) and export chats into this workspace. **Opt-in:** exported Markdown may contain sensitive content; only enable if you accept writing files under your workspace."
        },
        "cursorSync.outputDirectory": {
          "type": "string",
          "default": "",
          "markdownDescription": "Folder for exported `.md` and `index.json`. Leave empty for `<workspace>/.cursor/chats`. May be absolute or workspace-relative."
        },
        "cursorSync.debounceMs": {
          "type": "number",
          "default": 800,
          "minimum": 200,
          "maximum": 15000,
          "markdownDescription": "Wait this long after a storage file change before running an export (coalesces rapid DB writes)."
        }
      }
    }
  },
  "scripts": {
    "build": "tsc -b",
    "watch": "tsc -b -w",
    "vscode:prepublish": "pnpm run build",
    "vsix": "node ./scripts/package-vsix.mjs",
    "publish:openvsx": "node ./scripts/publish-openvsx.mjs"
  },
  "dependencies": {
    "@cursor-sync/core": "workspace:*",
    "chokidar": "^3.6.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/vscode": "^1.95.0",
    "@vscode/vsce": "2.32.0",
    "ovsx": "0.10.1"
  }
}
