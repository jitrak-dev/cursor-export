{
  "name": "cursor-export-monorepo",
  "private": true,
  "description": "Monorepo: core + VS Code extension (cursor-export)",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "prepare": "husky",
    "build": "tsc -b",
    "test": "pnpm build && pnpm -r test",
    "test:e2e": "pnpm build && pnpm --filter cursor-export run test:e2e",
    "lint": "eslint eslint.config.mjs \"packages/*/src/**/*.ts\" \"packages/*/test/**/*.ts\"",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "schema:dump": "tsx packages/core/scripts/knownSchema.ts dump",
    "schema:diff": "tsx packages/core/scripts/knownSchema.ts diff",
    "extension:package": "pnpm --filter cursor-export run vsix",
    "extension:publish": "pnpm extension:package && pnpm --filter cursor-export run publish:openvsx",
    "release": "semantic-release"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@eslint/js": "^9.17.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "husky": "^9.1.7",
    "prettier": "^3.4.2",
    "semantic-release": "^25.0.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1"
  },
  "packageManager": "pnpm@11.0.4"
}
