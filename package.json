{
  "name": "cursor-logs-monorepo",
  "private": true,
  "description": "Monorepo: core + VS Code extension (cursor-logs)",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "prepare": "husky",
    "build": "tsc -b",
    "test": "pnpm --filter @cursor-logs/core test",
    "lint": "eslint eslint.config.mjs \"packages/*/src/**/*.ts\" \"packages/*/test/**/*.ts\"",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "schema:dump": "tsx packages/core/scripts/knownSchema.ts dump",
    "schema:diff": "tsx packages/core/scripts/knownSchema.ts diff",
    "extension:package": "pnpm --filter cursor-logs run vsix",
    "extension:publish": "pnpm extension:package && pnpm --filter cursor-logs run publish:openvsx"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "husky": "^9.1.7",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1"
  },
  "packageManager": "pnpm@11.0.4"
}
