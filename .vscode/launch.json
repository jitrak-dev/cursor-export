{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/packages/vscode-ext"
      ],
      "outFiles": [
        "${workspaceFolder}/packages/vscode-ext/out/**/*.js",
        "${workspaceFolder}/packages/core/dist/**/*.js"
      ],
      "preLaunchTask": "pnpm: build"
    },
    {
      "name": "Run Extension (no pre-build)",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/packages/vscode-ext"
      ],
      "outFiles": [
        "${workspaceFolder}/packages/vscode-ext/out/**/*.js",
        "${workspaceFolder}/packages/core/dist/**/*.js"
      ]
    }
  ]
}
